<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service configuration for BlockerAccessibilityService.

    Key choices:
    - typeWindowStateChanged|typeWindowsChanged: catches both Activity transitions
      and window stack changes. typeWindowsChanged alone catches Custom Tab transitions
      and some in-app browser flows that don't fire typeWindowStateChanged.
    - flagRetrieveInteractiveWindows: lets us inspect all windows, not just the active
      one. Required if we ever want to read the URL bar.
    - canRetrieveWindowContent="true": mandatory for reading node info from windows.
      Matches Block app config (com.wverlaek.block accessibility_service.xml).
    - packageNames is empty — we watch all packages and filter in code via WatchedApps.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowsChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagReportViewIds"
    android:canPerformGestures="false"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="com.example.browserblock.SetupActivity" />
